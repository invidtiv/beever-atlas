# Beever Atlas v2 — Environment Variables
# Copy to .env and fill in values

# === 1. Core Application ===
BEEVER_API_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
VITE_API_URL=http://localhost:8000

# === 2. Internal Services & Databases ===
# MongoDB & Redis (Core state and queues)
MONGODB_URI=mongodb://localhost:27017/beever_atlas
REDIS_URL=redis://localhost:6379

# Weaviate (Vector search)
WEAVIATE_URL=http://localhost:8080
WEAVIATE_API_KEY=

# Graph Database ("neo4j", "nebula", or "none")
GRAPH_BACKEND=neo4j
# Neo4j Settings
NEO4J_URI=bolt://localhost:7687
NEO4J_AUTH=neo4j/beever_atlas_dev
# NebulaGraph Settings
NEBULA_HOSTS=127.0.0.1:9669
NEBULA_USER=root
NEBULA_PASSWORD=nebula
NEBULA_SPACE=beever_atlas

# === 3. External API & LLM Providers ===
# Primary LLM API (Google Gemini)
GOOGLE_API_KEY=                                         # Gemini models for ADK agents
LLM_FAST_MODEL=gemini-2.5-flash                         # Extraction, classification (low latency)
LLM_QUALITY_MODEL=gemini-2.5-flash                      # Cross-batch validation

# Local LLM Support
OLLAMA_ENABLED=false

# Embedding & Search
JINA_API_URL=https://api.jina.ai/v1/embeddings
JINA_API_KEY=                                           # Jina v4 embeddings
JINA_MODEL=jina-embeddings-v4
JINA_DIMENSIONS=2048
TAVILY_API_KEY=                                         # External web search (used by search_external_knowledge tool)

# === 4. Data Pipeline & Quality Gates ===
SYNC_BATCH_SIZE=50             # Messages per batch during sync
SYNC_MAX_MESSAGES=1000         # Max messages to fetch per sync
QUALITY_THRESHOLD=0.5          # Minimum fact quality score (0.0-1.0)
ENTITY_THRESHOLD=0.6           # Minimum entity confidence (0.0-1.0)
MAX_FACTS_PER_MESSAGE=2        # Max facts extracted per message
RECONCILER_INTERVAL_MINUTES=15 # Background retry interval for failed writes

# === 5. Integrations & Chat Bridge ===
ADAPTER_MOCK=true               # Set to "true" to use mock fixture data (no Slack needed)
BOT_PORT=3001                   # Bot HTTP server port
BACKEND_URL=http://localhost:8000  # Python backend URL (bot → backend)
BRIDGE_URL=http://localhost:3001   # Bot bridge URL (backend → bot)
BRIDGE_API_KEY=                    # Shared secret for bridge auth (optional in dev)

# === 6. QA Agent ===
# Confidence threshold — if retrieval scores below this, escalate to external search
QA_CONFIDENCE_THRESHOLD=0.4

# Outbound MCP servers — JSON array of {name, url, auth_token} for external tool providers
# Example: [{"name":"myserver","url":"http://host:8080","auth_token":"secret"}]
EXTERNAL_MCP_SERVERS=

# === 7. Security ===
CREDENTIAL_MASTER_KEY=             # 64-char hex key for AES-256-GCM credential encryption

# === 8. LLM resilience ===
# When true, fact/entity extractors pass a Pydantic schema to Gemini for
# constrained decoding, eliminating malformed-JSON EOF errors. Flip to false
# as a kill switch if an SDK regression is observed; json_recovery still
# handles fallback in either mode.
USE_LLM_STRUCTURED_OUTPUT=true

# === 9. Multilingual memory & rendering ===
# Detect source language per channel/message at ingestion and preserve it
# through memory. Wiki and QA render on demand in the chosen target language.
# Default OFF during rollout — flip to true when ready to ingest non-English.
LANGUAGE_DETECTION_ENABLED=false
DEFAULT_TARGET_LANGUAGE=en
SUPPORTED_LANGUAGES=en,zh-HK,zh-TW,zh-CN,ja,ko,es,fr,de,pt,it,nl,sv,da,no,fi,pl,cs,ru,uk,tr,ar,he,hi,th,el,vi,id
LANGUAGE_DETECTION_CONFIDENCE_THRESHOLD=0.6
