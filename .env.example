# Beever Atlas v2 — Environment Variables
# Copy to .env and fill in values.
#
# WARNING — values marked "change-me" or that include "dev" are DEV-ONLY
# placeholders. BEEVER_ENV=production enables fail-fast validation that
# refuses to start with defaults (master key, neo4j/nebula passwords,
# empty bridge/api/admin tokens).

# === 0. Deployment ===
# development | production | test
BEEVER_ENV=development

# === 1. Core Application ===
BEEVER_API_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
VITE_API_URL=http://localhost:8000

# === 1a. API Authentication ===
# Comma-separated Bearer tokens accepted by the backend. Clients send
# `Authorization: Bearer <token>`. Rotate before any deploy.
BEEVER_API_KEYS=dev-key-change-me
# Admin token required for /api/dev/* endpoints (X-Admin-Token header).
BEEVER_ADMIN_TOKEN=dev-admin-change-me

# === 1b. MCP (Model Context Protocol) server ===
#
# The sole MCP surface is /mcp (gated by BEEVER_MCP_ENABLED). It enforces
# bearer auth (BEEVER_MCP_API_KEYS) + per-tool channel ACL. The legacy
# unauthenticated /mcp mount has been retired.
#
# Comma-separated Bearer tokens for the /mcp mount consumed by external
# AI agents (Claude Code, Cursor, IDE assistants). Each key identifies one
# agent deployment. MUST be disjoint from BEEVER_API_KEYS and BRIDGE_API_KEY
# — a boot-time assertion fails otherwise.
BEEVER_MCP_API_KEYS=
# Mount the /mcp server (with auth middleware + ACL enforcement).
# Default off; flip to true to expose the MCP surface.
BEEVER_MCP_ENABLED=false
# MCP rate-limit backend. "memory" is a per-process sliding window (safe for
# single-worker deploys). "redis" uses REDIS_URL so counters are shared
# across workers — REQUIRED before flipping BEEVER_MCP_ENABLED=true in multi-
# worker production. Redis outages fall back to the memory limiter.
BEEVER_MCP_RATE_LIMIT_BACKEND=memory
# Enable HMAC dual-verification mode for one release cycle while migrating
# bridge callers to the new constant-time auth path (every legacy accept logs
# a warning). Default false.
BEEVER_BRIDGE_HMAC_DUAL=false
# JSON array of hostnames allowed for outbound MCP tool calls. Entries
# prefixed with "suffix:" match any host ending with that suffix (e.g.
# ["suffix:.sharepoint.com", "api.example.com"]). Default [] uses built-in
# defaults. The SSRF guard still rejects private IPs regardless of this list.
# (Must be valid JSON — pydantic-settings parses list[str] fields as JSON.)
EXTERNAL_MCP_ALLOWLIST=[]

# === 2. Internal Services & Databases ===
# MongoDB & Redis (core state and queues)
MONGODB_URI=mongodb://localhost:27017/beever_atlas
REDIS_URL=redis://localhost:6379

# Chat-history MongoDB URI — separate collection for QA conversation turns.
# Defaults to the same database as MONGODB_URI when unset.
BEEVER_CHAT_HISTORY_DB=

# Weaviate (vector search)
WEAVIATE_URL=http://localhost:8080
WEAVIATE_API_KEY=

# Graph backend: "neo4j", "nebula", or "none"
GRAPH_BACKEND=neo4j

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_AUTH=neo4j/beever_atlas_dev
# Password used by docker-compose to initialize the Neo4j container
# (must match the password half of NEO4J_AUTH above).
NEO4J_PASSWORD=beever_atlas_dev

# NebulaGraph
NEBULA_HOSTS=127.0.0.1:9669
NEBULA_USER=root
NEBULA_PASSWORD=nebula
NEBULA_SPACE=beever_atlas

# === 3. External API & LLM Providers ===
# Gemini models for ADK agents
GOOGLE_API_KEY=
# Extraction, classification (low latency)
LLM_FAST_MODEL=gemini-2.5-flash
# Cross-batch validation
LLM_QUALITY_MODEL=gemini-2.5-flash
# Hybrid search BM25/vector blend (0.0 = pure BM25, 1.0 = pure vector)
WEAVIATE_HYBRID_ALPHA=0.6

# OpenAI API key — used by the Whisper transcription client (audio/video pipeline).
# Only required when MEDIA_AUDIO_MAX_DURATION_MINUTES > 0.
OPENAI_API_KEY=
# Whisper transcription endpoint. Defaults to the OpenAI public endpoint;
# override with a self-hosted Whisper server.
WHISPER_API_URL=https://api.openai.com/v1/audio/transcriptions

# Local LLM support
OLLAMA_ENABLED=false
# Base URL for the local Ollama server (e.g. http://localhost:11434).
OLLAMA_API_BASE=http://localhost:11434

# Jina v4 embeddings
JINA_API_URL=https://api.jina.ai/v1/embeddings
JINA_API_KEY=
JINA_MODEL=jina-embeddings-v4
JINA_DIMENSIONS=2048

# External web search (used by search_external_knowledge tool)
TAVILY_API_KEY=

# === 4. Data Pipeline & Quality Gates ===
# Messages per batch during sync
SYNC_BATCH_SIZE=50
# Max messages to fetch per sync
SYNC_MAX_MESSAGES=1000
# Minimum fact quality score (0.0-1.0)
QUALITY_THRESHOLD=0.5
# Minimum entity confidence (0.0-1.0)
ENTITY_THRESHOLD=0.6
# Max facts extracted per message
MAX_FACTS_PER_MESSAGE=2
# Background retry interval for failed writes
RECONCILER_INTERVAL_MINUTES=15
# Timeout per batch during sync (seconds). Raise if large channels time out.
SYNC_BATCH_TIMEOUT_SECONDS=600

# Semantic search — minimum cosine similarity for vector results (0.0-1.0).
# Results below this threshold are dropped before returning to the caller.
SEMANTIC_SEARCH_MIN_SIMILARITY=0.7

# Contradiction detection thresholds (0.0-1.0).
# CONFIDENCE: above this score a new fact is treated as a confident update.
# FLAG: below this score an overlap is flagged but not auto-resolved.
CONTRADICTION_CONFIDENCE_THRESHOLD=0.8
CONTRADICTION_FLAG_THRESHOLD=0.5

# Orphan entities older than this many days are eligible for soft-deletion.
ORPHAN_GRACE_PERIOD_DAYS=7

# Clustering thresholds for the consolidation pipeline.
# SIMILARITY: minimum vector similarity to place two facts in the same cluster.
# MERGE: minimum similarity to auto-merge two cluster members.
# MAX_SIZE: maximum facts per cluster before splitting.
CLUSTER_SIMILARITY_THRESHOLD=0.6
CLUSTER_MERGE_THRESHOLD=0.85
CLUSTER_MAX_SIZE=100
# Max concurrent in-flight LLM calls during consolidation batches.
CONSOLIDATION_MAX_CONCURRENT_LLM=5
# Master switch for the consolidation pipeline. Set false to skip all
# cross-batch deduplication (useful during initial bulk ingest).
CONSOLIDATION_ENABLED=true

# Citation registry — enables [src:xxx] → [N] rewriting at stream time.
# Set false to revert to the legacy regex citation path as a kill switch.
CITATION_REGISTRY_ENABLED=true

# Gemini Batch API — off by default; flip USE_BATCH_API=true to route
# fact/entity extraction through Gemini's async batch endpoint.
USE_BATCH_API=false
BATCH_POLL_INTERVAL_SECONDS=15
BATCH_MAX_WAIT_SECONDS=3600
BATCH_MAX_PROMPT_TOKENS=6000
BATCH_TIME_WINDOW_SECONDS=600

# After this many consecutive Gemini 5xx errors, fail fast instead of burning
# per-batch retry budget (circuit-breaker threshold).
LLM_OUTAGE_BREAKER_THRESHOLD=3
# Per-extractor retry attempts before propagating the error upstream.
FACT_MAX_RETRIES=3
# Jobs older than this many hours are considered stale and eligible for reaping.
STALE_JOB_THRESHOLD_HOURS=1.0

# === 4a. Coreference Resolution ===
# Resolve pronouns / implicit entity references before extraction.
COREF_ENABLED=true
# Max conversation turns fed to the coreference resolver for context.
COREF_HISTORY_LIMIT=20
# Gemini model used for coreference resolution (can be overridden to a smaller
# model if latency is critical).
COREF_MODEL=gemini-2.5-flash

# === 4b. Semantic Entity Deduplication ===
# Cosine similarity threshold above which two entities are merged (0.0-1.0).
ENTITY_SIMILARITY_THRESHOLD=0.85
# How long (days) a rejected merge proposal is suppressed before reconsidering.
MERGE_REJECTION_TTL_DAYS=30

# === 4c. Cross-Batch Thread Context ===
# Feed the last N characters of thread context across batch boundaries so
# later batches can resolve back-references.
CROSS_BATCH_THREAD_CONTEXT_ENABLED=true
THREAD_CONTEXT_MAX_LENGTH=200

# === 5. Integrations & Chat Bridge ===
# Set to "true" to use mock fixture data (no Slack needed)
ADAPTER_MOCK=true
# Bot HTTP server port
BOT_PORT=3001
# Python backend URL (bot → backend)
BACKEND_URL=http://localhost:8000
# Bot bridge URL (backend → bot)
BRIDGE_URL=http://localhost:3001
# Shared secret for bridge auth. REQUIRED — the bridge rejects every
# request when this is unset, except for local development that also
# sets BRIDGE_ALLOW_UNAUTH=true (see below). Was previously treated as
# "optional in dev"; the bypass is now explicit per security finding M1.
BRIDGE_API_KEY=
# Local-dev-only opt-in for an unauthenticated bridge. The string MUST
# be exactly "true" (not "1"/"yes"/"TRUE"). Leave unset in any
# non-local environment. Running with this flag emits a loud warning on
# startup.
BRIDGE_ALLOW_UNAUTH=

# Optional comma-separated override for the file-proxy platform
# allowlist. Entries prefixed with "suffix:" match any host ending with
# the suffix (e.g. suffix:.sharepoint.com). Leave unset to use the built
# in defaults (Slack, Discord, Teams/SharePoint, Telegram, Mattermost).
FILE_PROXY_HOST_ALLOWLIST=

# === 5a. Chat Platform Credentials ===
# Each block unlocks the corresponding platform adapter in the chat bridge.
# Set __REQUIRED__ values to real secrets; leave blank to disable that adapter.

# Slack — enables the Slack Events API + slash commands adapter.
SLACK_BOT_TOKEN=__REQUIRED__
SLACK_SIGNING_SECRET=__REQUIRED__

# Discord — enables the Discord interactions webhook adapter.
DISCORD_BOT_TOKEN=__REQUIRED__
DISCORD_PUBLIC_KEY=__REQUIRED__
DISCORD_APPLICATION_ID=__REQUIRED__

# Microsoft Teams — enables the Azure Bot Framework adapter.
TEAMS_APP_ID=__REQUIRED__
TEAMS_APP_PASSWORD=__REQUIRED__

# Telegram — enables the Telegram Bot API webhook adapter.
TELEGRAM_BOT_TOKEN=__REQUIRED__

# Mattermost — enables the Mattermost outgoing-webhook adapter.
MATTERMOST_BASE_URL=https://your-mattermost-server.example.com
MATTERMOST_BOT_TOKEN=__REQUIRED__

# === 6. QA Agent ===
# Confidence threshold — if retrieval scores below this, escalate to external search
QA_CONFIDENCE_THRESHOLD=0.4
# Outbound MCP servers — JSON array of {name, url, auth_token} for external tool providers
# Example: [{"name":"myserver","url":"http://host:8080","auth_token":"secret"}]
EXTERNAL_MCP_SERVERS=
# Token-by-token streaming via ADK SSE mode (set 0 to disable)
QA_ADK_STREAMING_SSE=1
# Strengthened OUTPUT_CONTRACT: headings, bullet lists, markdown tables, ≤150-word prose-block cap
QA_RICH_OUTPUT=true
# ADK Agent Skills progressive disclosure (8 skills). Requires QA_RICH_OUTPUT=true.
QA_SKILLS_ENABLED=true
# Log a warning when a non-deep response exceeds 1500 chars (warn-only, no truncation).
QA_ONBOARDING_LENGTH_MONITOR=true
# Drop QA history entries classified as "refused" so the agent can't recycle hollow non-answers.
QA_HISTORY_NEGATIVE_FILTER=false

# === 7. Security ===
# DEV ONLY — UNSAFE FOR PROD — regenerate before deploy
# (`python -c "import secrets; print(secrets.token_hex(32))"`).
# Production (BEEVER_ENV=production) rejects this placeholder.
CREDENTIAL_MASTER_KEY=00000000000000000000000000000000000000000000000000000000deadbeef

# Channel ownership gate. Default true preserves single-operator behaviour
# (legacy:shared / missing-owner connections are reachable by any
# authenticated user). Flip to false once each connection has been stamped
# with an explicit owner_principal_id so channel-scoped routes enforce
# per-principal access.
BEEVER_SINGLE_TENANT=true

# Emergency override for security finding H4. Default false. When true,
# the internal BRIDGE_API_KEY is accepted on user-facing routes — reopens
# the cross-tenant super-admin path. Every boot with this flag on logs
# a loud warning.
BEEVER_ALLOW_BRIDGE_AS_USER=false

# === 8. LLM resilience ===
# When true, fact/entity extractors pass a Pydantic schema to Gemini for
# constrained decoding, eliminating malformed-JSON EOF errors. Flip to false
# as a kill switch if an SDK regression is observed; json_recovery still
# handles fallback in either mode.
USE_LLM_STRUCTURED_OUTPUT=true

# === 9. Multilingual memory & rendering ===
# Detect source language per channel/message at ingestion and preserve it
# through memory. Wiki and QA render on demand in the chosen target language.
# Default OFF during rollout — flip to true when ready to ingest non-English.
LANGUAGE_DETECTION_ENABLED=false
DEFAULT_TARGET_LANGUAGE=en
SUPPORTED_LANGUAGES=en,zh-HK,zh-TW,zh-CN,ja,ko,es,fr,de,pt,it,nl,sv,da,no,fi,pl,cs,ru,uk,tr,ar,he,hi,th,el,vi,id
LANGUAGE_DETECTION_CONFIDENCE_THRESHOLD=0.6

# === 10. Wiki Compiler ===
# Phases 1-3 are pure stability/speed wins — safe to leave ON.
# Phase 1: control-char sanitizer, degenerate-content guard, retry gating
BEEVER_WIKI_PARSE_HARDENING=1
# Phase 2: parallelize title translation with page dispatch
BEEVER_WIKI_PARALLEL_DISPATCH=1
# Phase 3: per-page-kind max_output_tokens budgets
BEEVER_WIKI_TOKEN_BUDGET_V2=1
# Phase 4+5: deterministic Key Facts table, thin-topic path, delimited parser. Default OFF.
BEEVER_WIKI_COMPILER_V2=0

# === 11. Ingestion Pipeline Tuning ===
# Inter-batch concurrency — how many batches run in parallel within one sync.
# Raise if semaphore_wait_s_p95 is high; lower if you hit Gemini 429s.
INGEST_BATCH_CONCURRENCY=4
# Intra-batch: parallel fact-vs-existing contradiction checks per batch.
CONTRADICTION_CONCURRENCY=4
# Intra-batch: parallel per-image Gemini descriptions in preprocessor.
IMAGE_EXTRACTOR_CONCURRENCY=4
# Provider rate ceilings (requests per minute). Keep below your quota.
GEMINI_RPM=300
JINA_RPM=500
# Per-batch output token ceiling (~5% below Gemini 2.5 Flash's 65k output ceiling).
BATCH_MAX_OUTPUT_TOKENS=24000

# === 12. Media Pipeline ===
# Maximum video file duration to process (minutes). Longer videos are rejected.
MEDIA_VIDEO_MAX_DURATION_MINUTES=10
# Maximum video file size to process (MB).
MEDIA_VIDEO_MAX_SIZE_MB=100
# Maximum audio file duration to process (minutes).
MEDIA_AUDIO_MAX_DURATION_MINUTES=30
# Maximum characters extracted from Office documents (docx/xlsx/pptx).
MEDIA_OFFICE_MAX_CHARS=10000
# Maximum file size accepted by the media pipeline (MB).
MEDIA_MAX_FILE_SIZE_MB=20
# Timeout for Gemini vision calls on media files (seconds).
MEDIA_VISION_TIMEOUT_SECONDS=180
# Gemini model used for vision/image description in media processing.
MEDIA_VISION_MODEL=gemini-2.5-flash
# Comma-separated image MIME extensions accepted by the media pipeline.
MEDIA_SUPPORTED_IMAGE_TYPES=png,jpg,jpeg,gif,webp
# Enable the LLM-based document digest step. Set false to skip expensive
# LLM calls during media processing (faster but less descriptive).
MEDIA_DIGEST_ENABLED=true

# === 13. PDF Extraction ===
# Pages per chunk when extracting large PDFs via the chunked path.
PDF_CHUNK_PAGES=4
# Hard cap on pages to process per PDF file.
PDF_MAX_PAGES=100
# When true, a single-pass LLM summary is generated for large PDFs instead
# of chunked extraction (faster, lower fidelity).
PDF_SUMMARIZE_LARGE_DOCS=false
# PDFs with more than this many pages trigger the "large doc" path.
PDF_LARGE_DOC_THRESHOLD=50

# === 14. File Import ===
# Enable LLM-assisted column mapping when importing CSV/XLSX message exports.
FILE_IMPORT_LLM_MAPPING_ENABLED=true
# Local directory for staging imported files before ingest.
FILE_IMPORT_STAGING_DIR=.omc/imports
# How long (seconds) a staged import file is retained before cleanup.
FILE_IMPORT_STAGING_TTL_SECONDS=3600
# Maximum rows processed per file import job.
FILE_IMPORT_MAX_ROWS=100000

# === 15. Web Build-Time Variables ===
# These are baked into the Vite bundle at build time and therefore
# PUBLIC-VISIBLE in the browser. Do NOT put secrets here.
# Changing them requires a full rebuild (npm run build).
#
# Public URL of the Beever Atlas backend API.
# VITE_API_URL=http://localhost:8000  (already set in section 1 above)
#
# API key injected into every /api/* request as "Authorization: Bearer <key>".
# Should match one of the values in BEEVER_API_KEYS. Since this is baked
# into the browser bundle it must be treated as a low-privilege read-only key.
VITE_BEEVER_API_KEY=
# Admin token sent as X-Admin-Token for /api/dev/* calls from the web UI.
# Should match BEEVER_ADMIN_TOKEN. Same caveat: it is public once built.
VITE_BEEVER_ADMIN_TOKEN=
