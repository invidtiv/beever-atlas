{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "WikiDecisionsKindSchema",
  "description": "Structured record of decisions in this channel, with alternatives and rationale.",
  "type": "object",
  "required": ["decisions"],
  "additionalProperties": false,
  "properties": {
    "decisions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["title"],
        "additionalProperties": false,
        "properties": {
          "title":        { "type": "string" },
          "decided_at":   { "type": "string", "default": "not stated" },
          "decided_by":   { "type": "string", "default": "not stated" },
          "alternatives": {
            "type": "array",
            "items": { "type": "string" },
            "default": []
          },
          "rationale":    { "type": "string", "default": "" },
          "affected":     {
            "type": "array",
            "items": { "type": "string" },
            "default": []
          }
        }
      }
    }
  }
}
