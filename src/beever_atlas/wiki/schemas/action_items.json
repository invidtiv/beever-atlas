{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "WikiActionItemsKindSchema",
  "description": "Kanban grouped by status — todo / in_progress / blocked / done.",
  "type": "object",
  "required": ["items"],
  "additionalProperties": false,
  "properties": {
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["title", "status"],
        "additionalProperties": false,
        "properties": {
          "title":  { "type": "string" },
          "status": {
            "type": "string",
            "enum": ["todo", "in_progress", "blocked", "done"]
          },
          "owner":  { "type": "string", "default": "unassigned" },
          "due":    { "type": "string", "default": "not stated" },
          "blocked_by": {
            "type": "array",
            "items": { "type": "string" },
            "default": []
          },
          "related_pages": {
            "type": "array",
            "items": { "type": "string" },
            "default": []
          }
        }
      }
    }
  }
}
