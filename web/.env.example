# Base URL of the Beever Atlas backend API. Vite bakes this in at build time.
VITE_API_URL=http://localhost:8000

# API key sent as `Authorization: Bearer <key>` on every /api/* request (except /api/health).
# Must match one of the comma-separated values in BEEVER_API_KEYS on the server.
VITE_BEEVER_API_KEY=dev-key-change-me

# Admin token for /api/dev/* endpoints (development only).
# Must match BEEVER_ADMIN_TOKEN in root .env. Unset in prod builds.
VITE_BEEVER_ADMIN_TOKEN=dev-admin-change-me
